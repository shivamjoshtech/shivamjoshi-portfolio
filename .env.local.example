NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Admin Authentication (set your own secret password)
ADMIN_SECRET_KEY=shivam_admin_2025_secret

# AI Integration (FREE — pick one)
# Option A: Groq (Free tier — recommended)
# Sign up at https://console.groq.com → Create API key
GROQ_API_KEY=your_groq_api_key

# Option B: Google Gemini (Free tier)
# Sign up at https://aistudio.google.com → Get API key
GEMINI_API_KEY=your_gemini_api_key

